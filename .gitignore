node_modules/
*.log
.cbm/

# session scratch (commit-msg drafts, one-off popup runners/smokes) — never tracked
.commit-msg-*.txt
.run-*.cmd
.smoke-*.cjs
.spawn-*.cjs

# secrets — never track a provider key (.env was a real hole; a fresh clone must not risk committing it)
.env
.env.*
!.env.example

# --- Toshi diag/scratch (never track) ---
# local diag scripts that pre-date the live dev harness (tools/verify-toshi.cjs, tools/launch-toshi.cjs).
# These probe paths we know are dead or one-off (mirror P2P iCaptcha, WSL shims, ad-hoc ping).
tools/diag-bin.cjs
tools/diag-bin2.cjs
tools/diag-env.ps1
tools/mirror-probe.cjs
tools/wsl-*.sh
.check-*.cjs
.ping-*.cjs

# --- Zero / session scratch (never track) ---
# .claude/ is Zero's per-session scratch dir (commit-msg drafts, smoke runners, live probes).
# It MUST be ignored: a stray `git add .` would otherwise dump ephemeral session files.
.claude/
.toshi.pid
.toshi-launch.log
.test-out.txt
